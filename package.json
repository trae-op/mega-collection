{
  "name": "@devisfuture/mega-collection",
  "version": "2.3.1",
  "description": "High-performance search, filter & sort engine for 100K+ item collections in JavaScript/TypeScript",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./search": {
      "types": "./dist/search/index.d.mts",
      "default": "./dist/search/index.mjs"
    },
    "./filter": {
      "types": "./dist/filter/index.d.mts",
      "default": "./dist/filter/index.mjs"
    },
    "./sort": {
      "types": "./dist/sort/index.d.mts",
      "default": "./dist/sort/index.mjs"
    },
    "./merge": {
      "types": "./dist/merge/index.d.mts",
      "default": "./dist/merge/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "search": [
        "./dist/search/index.d.mts"
      ],
      "filter": [
        "./dist/filter/index.d.mts"
      ],
      "sort": [
        "./dist/sort/index.d.mts"
      ],
      "merge": [
        "./dist/merge/index.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:package": "npm run build && node scripts/prepare-package.mjs",
    "build:watch": "tsup --watch",
    "dev": "tsup --watch",
    "pack:package": "npm run build:package && npm pack --json --dry-run ./package",
    "publish:package": "npm run build:package && npm publish ./package --access public",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose --reporter=json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build:package",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "javascript",
    "search",
    "filter",
    "sort",
    "collection",
    "performance",
    "trigram",
    "inverted-index",
    "hashmap",
    "large-dataset",
    "big-data",
    "typescript",
    "zero-dependencies",
    "tree-shakeable",
    "esm",
    "indexer",
    "50k",
    "100k",
    "text-search",
    "multi-filter",
    "sort-engine",
    "merge-engines",
    "o1-lookup"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trae-op/mega-collection.git"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.1.8"
  },
  "license": "MIT"
}
