{
  "name": "@devisfuture/mega-collection",
  "version": "1.0.0",
  "description": "High-performance search, filter & sort engine for 10M+ item collections in JavaScript/TypeScript",
  "exports": {
    "./search": {
      "import": {
        "types": "./dist/search/index.d.mts",
        "default": "./dist/search/index.mjs"
      },
      "require": {
        "types": "./dist/search/index.d.ts",
        "default": "./dist/search/index.js"
      }
    },
    "./filter": {
      "import": {
        "types": "./dist/filter/index.d.mts",
        "default": "./dist/filter/index.mjs"
      },
      "require": {
        "types": "./dist/filter/index.d.ts",
        "default": "./dist/filter/index.js"
      }
    },
    "./sort": {
      "import": {
        "types": "./dist/sort/index.d.mts",
        "default": "./dist/sort/index.mjs"
      },
      "require": {
        "types": "./dist/sort/index.d.ts",
        "default": "./dist/sort/index.js"
      }
    }
  },
  "typesVersions": {
    "*": {
      "search": [
        "./dist/search/index.d.ts"
      ],
      "filter": [
        "./dist/filter/index.d.ts"
      ],
      "sort": [
        "./dist/sort/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "search",
    "filter",
    "sort",
    "performance",
    "large-dataset",
    "10-million",
    "index",
    "trigram",
    "collection",
    "big-data",
    "hash-map",
    "mega-collection"
  ],
  "author": "devisfuture",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devisfuture/mega-collection.git"
  },
  "bugs": {
    "url": "https://github.com/devisfuture/mega-collection/issues"
  },
  "homepage": "https://github.com/devisfuture/mega-collection#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
